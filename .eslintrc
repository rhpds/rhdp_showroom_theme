{
  "extends": "standard",
  "env": {
    "browser": true
  },
  "rules": {
    "arrow-parens": ["error", "always"],
    "comma-dangle": ["error", {
      "arrays": "always-multiline",
      "objects": "always-multiline",
      "imports": "always-multiline",
      "exports": "always-multiline"
    }],
    "max-len": [1, 120, 2],
    "no-var": "off",
    "object-shorthand": "off",
    "spaced-comment": "off",
    "padded-blocks": "off"
  }
}
